# Web MVP model API. Local backend also reads existing .env, so DEEPSEEK_API_KEY can stay there.
MODEL_API_BASE_URL=https://api.deepseek.com/v1
MODEL_API_KEY=replace-with-your-api-key
MODEL_API_MODEL=deepseek-chat
MODEL_TIMEOUT_SEC=45

# Docker service passwords. Change before sharing outside your machine.
POSTGRES_PASSWORD=fae
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=fae-attachments

# Optional local overrides.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
OBJECT_STORAGE_MODE=local

# Knowledge base / vector index.
# file_scan always reads the current files under reference/documents and file_library.
# Set EMBEDDING_MODE=api for better qdrant_vector retrieval quality.
RAG_ENABLED=true
RAG_AUTO_INDEX=false
MAX_INDEX_FILE_BYTES=30000000
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=fae_knowledge_chunks
EMBEDDING_MODE=local
EMBEDDING_VECTOR_SIZE=384
# EMBEDDING_MODE=api
# EMBEDDING_API_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=replace-with-your-embedding-api-key
# EMBEDDING_API_MODEL=text-embedding-3-small

# Optional GitLab SDK version mapping.
# GITLAB_PROJECT can be numeric project id or namespace/project path, e.g. firmware/sdk-xc65.
GITLAB_BASE_URL=
GITLAB_PROJECT=
GITLAB_TOKEN=
GITLAB_REF_PATTERNS={version},v{plain},sdk-{version},sdk-{plain},release/{version},release/{plain}
GITLAB_RELEASE_NOTE_PATHS=ReleaseNotes.md,RELEASE_NOTES.md,CHANGELOG.md,CHANGELOG.txt,docs/ReleaseNotes.md,docs/release_notes.md
